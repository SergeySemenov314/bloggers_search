# Ключ Claude API. Скопируйте этот файл в .env и подставьте свой ключ.
ANTHROPIC_API_KEY=sk-ant-...

# ID Google-таблицы с блогерами (из ссылки docs.google.com/spreadsheets/d/<ID>/edit)
SHEET_ID=1J1HtHP-CMQ8skFOuFtspu2GhmSzeWPcehmrAK-P6gR4
SHEET_GID=0

# Ник Instagram для сбора данных через залогиненную сессию.
# Анонимный доступ IG режет (429), поэтому нужен разовый логин:
#   instaloader --login=ВАШ_НИК
# (пароль введёте в консоли; создастся файл сессии). Затем впишите ник сюда.
# Совет: используйте второй/левый аккаунт, не основной.
IG_USERNAME=
